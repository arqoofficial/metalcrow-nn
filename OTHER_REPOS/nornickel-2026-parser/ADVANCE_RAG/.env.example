# Secrets for ADVANCE_RAG (not committed in production)
# Host path to SHARED (repo root by default; override if your layout differs)
SHARED_PATH=../SHARED
# Use redis queue when API and worker run in separate containers (Docker default)
QUEUE_BACKEND=redis
ADVANCE_RAG_ONNX_MODEL_DIR=/app/assets/models/chroma/onnx_models/all-MiniLM-L6-v2
ADVANCE_RAG_NLTK_DATA=/app/assets/nltk_data
ADVANCE_RAG_RERANKER_STOPWORDS=/app/assets/reranker/stopwords.txt
CHROMA_OPENAI_API_KEY=
CHROMA_OPENAI_BASE_URL=
OTEL_EXPORTER_OTLP_ENDPOINT=
REDIS_URL=redis://redis:6379/0
