# Redis
REDIS_URL=redis://:password@redis-host:6379/0

# Worker offline model contract
REQUIRE_PRELOADED_MODELS=true

# OCR GPU mode for workers: auto|true|false
# auto — use GPU when CUDA is available inside the container (requires GPU image + compose.gpu.yml)
DOC_OCR_USE_GPU=auto
# GPU count for docker-compose.gpu.yml worker reservations (0 = CPU-only compose)
DOCKER_GPU_COUNT=1
