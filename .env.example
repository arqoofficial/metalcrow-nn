# Used by the backend to generate links in emails to the frontend.
# The frontend is served on a single public port, so no port is needed here
# on the server (nginx listens on 80, the default HTTP port).
FRONTEND_HOST=http://localhost:5173
# On the hackathon server:
# FRONTEND_HOST=http://<server-ip>

# Environment: local, staging, production
ENVIRONMENT=local

PROJECT_NAME="Full Stack FastAPI Project"

# Backend
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:5173,https://localhost,https://localhost:5173"
SECRET_KEY=changethis
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=changethis

# Frontend build: URL the browser uses to reach the backend API, baked into
# the frontend bundle at build time. Leave empty (default, recommended): the
# app then calls a relative path (/api/v1/...) and nginx proxies it to the
# backend container internally, so the same image works on localhost, any
# server IP or domain without a rebuild.
VITE_API_URL=

# Host ports (all optional, defaults shown below, only used locally via
# compose.override.yml — the server overlay only ever publishes the
# frontend port, see compose.prod.yml).
# FRONTEND_PORT=5173
# BACKEND_PORT=8000
# ADMINER_PORT=8080
# REDIS_PORT=6379
# MINIO_PORT=9000
# MINIO_CONSOLE_PORT=9001
# PARSER_PORT=8114
# NEO4J_HTTP_PORT=7474
# NEO4J_BOLT_PORT=7687

# Redis — Celery broker (svc-parse-docling) + query cache
REDIS_URL=redis://redis:6379/0

# nornickel-2026-parser — single file source (all raw/OKF/chunks under
# services/nornickel-2026-parser/SHARED/, read/write only via HTTP API).
# Started separately: `make up` brings parser + metalcrow on shared `metalcrow-net`.
# Alias on the network: parser-main:8114
PARSER_URL=http://parser-main:8114

# MinIO — S3-compatible object storage for litsearch PDFs and provenance sources
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changethis
MINIO_BUCKET=metalcrow-documents
MINIO_ENDPOINT=minio:9000
# Browser-reachable host for presigned URLs (mapped MinIO port on the host)
MINIO_PUBLIC_ENDPOINT=localhost:9000
MINIO_SECURE=false

# Neo4j — optional graph DB (SPEC_V3 §3 п.8, P1). Graph API degrades to
# 503/SQL fallback when unreachable, see app/services/graph.py.
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changethis

# science-knowledge-graph — standalone spaCy/scispaCy + Neo4j GraphRAG sidecar (internal-only).
# Used for /rag/query LLM answer generation. Provider and model must match:
#   OpenAI direct: OPENAI_BASE_URL=https://api.openai.com/v1  OPENAI_MODEL=gpt-4o-mini
#   ProxyAPI:      OPENAI_BASE_URL=https://api.proxyapi.ru/openai/v1  OPENAI_MODEL=gpt-4o-mini
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.proxyapi.ru/openai/v1
OPENAI_MODEL=gpt-4o-mini

# ontology-knowledge-graph — типизированная онтология (Postgres sidecar, internal-only).
# Backend вызывает по HTTP; при недоступности чат деградирует на hybrid_search.
# ONTOLOGY_KG_URL=http://ontology-knowledge-graph:8000
# ONTOLOGY_DB_URL=postgresql://postgres:changethis@db:5432/ontology
# ONTOLOGY_AUTOLOAD=1

# litsearch → chat integration: article-fetcher (OpenAlex search + PDF fetch,
# port 8200) wired into the chat tool loop via a server-side Celery pipeline.
ARTICLE_FETCHER_URL=http://article-fetcher:8200   # NB: 8200, the fetcher's real port
OPENALEX_MAILTO=
# LLM for the litsearch tool loop (OpenAI-compatible gateway; LiteLLM +
# Langfuse, spec §2.8). Committed default points at the shared gateway; set
# LLM_API_KEY to your own key. Empty LLM_BASE_URL keeps the feature inert (no
# fabricated answer — llm.chat/llm.complete degrade explicitly).
LLM_BASE_URL=https://llm.autumn-lab.uk/v1
LLM_API_KEY=
LLM_MODEL=deepseek/deepseek-v4-flash__or
LLM_TIMEOUT=60

LITSEARCH_API_KEY=
# опционально, если не задан — уже дефолт https://llm.autumn-lab.uk/v1
LITSEARCH_BASE_URL=https://llm.autumn-lab.uk/v1

LITSEARCH_MAX_RESULTS=5
LITSEARCH_MAX_ROUNDS=2
LITSEARCH_FULLTEXT_CHAR_CAP=60000
LITSEARCH_FETCH_TIMEOUT=180
LITSEARCH_INGEST_ENABLED=true   # add-to-DB ingest: true=full hard-parse->graph/ontology (A, OSN-approved default), false=stage Document at L0 only (B)

# ReAct-агент чата (SPEC_V3 §5.7). Включён по умолчанию: планирует вызовы тулов
# ретрива и синтезирует claims. Использует общий LLM (LLM_BASE_URL/LLM_API_KEY/
# LLM_INTENT_MODEL выше). При пустом LLM или любой ошибке — откат на прежний
# детерминированный водопад ontology → knowledge_graph, поэтому безопасен.
# LLM_AGENT_ENABLED=false   # раскомментировать, чтобы жёстко только водопад
# Опционально — отдельный LLM-эндпоинт/модель для агента (иначе берётся общий):
# LLM_AGENT_GATEWAY_URL=
# LLM_AGENT_API_KEY=
# LLM_AGENT_MODEL=

# Emails
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=info@example.com
SMTP_TLS=True
SMTP_SSL=False
SMTP_PORT=587

# Postgres
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changethis

SENTRY_DSN=
