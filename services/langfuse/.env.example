# Copy to .env, set LANGFUSE_DOMAIN, then run ./gen-secrets.sh to fill every blank below
# (crypto secrets, internal passwords, admin password, and the gateway's project keys).
# NEVER commit .env. NOTE: no inline comments on value lines — docker-compose reads them literally.

# Public hostname (served by the gateway's Caddy; DNS A-record -> the gateway VM).
LANGFUSE_DOMAIN=langfuse.autumn-lab.uk

# Internal service credentials (gen-secrets.sh fills the blanks).
LANGFUSE_DB_USER=postgres
LANGFUSE_DB_PASSWORD=
LANGFUSE_DB_NAME=postgres
LANGFUSE_CLICKHOUSE_USER=clickhouse
LANGFUSE_CLICKHOUSE_PASSWORD=
LANGFUSE_MINIO_USER=minio
LANGFUSE_MINIO_PASSWORD=

# Auth / crypto secrets (gen-secrets.sh fills these; ENCRYPTION_KEY = 64 hex chars / 256-bit).
NEXTAUTH_SECRET=
SALT=
ENCRYPTION_KEY=

# Initial admin, seeded on first boot (gen-secrets.sh sets the password if blank).
LANGFUSE_INIT_USER_EMAIL=admin@metalcrow.local
LANGFUSE_INIT_USER_NAME=Admin
LANGFUSE_INIT_USER_PASSWORD=

# Project API keys handed to the LiteLLM gateway (gen-secrets.sh fills these).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
