# Copy to .env and fill from ../../safe/ (relative to the metalcrow repo root).
# NEVER commit .env — it is git-ignored. See README for a one-shot assembly command.

# --- Yandex (PRIMARY) ---
YANDEX_API_KEY_1=            # ../safe/nornickel_hack_yandex_api_key   (an "AQVN..." Api-Key)
YANDEX_FOLDER_ID=           # ../safe/nornickel_hack_yandex_folder_id
# YANDEX_API_KEY_2=         # add a 2nd Yandex key to activate intra-provider (Layer-1) failover

# --- OpenRouter (FALLBACK) ---
OPENROUTER_API_KEY_1=       # ../safe/nornickel_hack_or_key   (sk-or-...)
OPENROUTER_API_KEY_2=       # ../safe/or_key_0                (sk-or-...)

# --- Langfuse (SHARED, project-scoped: org "Metalcrow" / project "metalcrow-gateway") ---
LANGFUSE_PUBLIC_KEY=        # ../safe/langfuse-metalcrow.env
LANGFUSE_SECRET_KEY=        # ../safe/langfuse-metalcrow.env
# Containerised proxy reaches Langfuse by internal service name on cosmetic-agent_default:
LANGFUSE_HOST=http://langfuse-server:3000

# --- Proxy admin ---
LITELLM_MASTER_KEY=sk-      # set a strong random master key (guards admin/key endpoints)

# --- Admin UI + DB (enables the /ui login, virtual keys, request logs) ---
LITELLM_DB_PASSWORD=        # postgres password for the litellm-db service
LITELLM_UI_USERNAME=admin   # username for the LiteLLM admin UI login
LITELLM_UI_PASSWORD=        # password for the LiteLLM admin UI login
